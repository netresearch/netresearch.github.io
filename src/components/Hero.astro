---
interface Props {
  totalRepos: number;
}
const { totalRepos } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-nr-dark via-nr-dark-lighter to-nr-dark"></div>
  <div class="absolute top-1/4 -left-1/4 w-[600px] h-[600px] bg-nr-teal/8 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-1/4 -right-1/4 w-[400px] h-[400px] bg-nr-orange/6 rounded-full blur-[100px]"></div>
  <div class="absolute top-0 right-0 w-1 h-full bg-gradient-to-b from-transparent via-nr-teal/20 to-transparent transform rotate-12 translate-x-[40vw]"></div>

  <div class="relative z-10 text-center px-6 max-w-5xl" data-animate="fade-up">
    <img src="/img/favicon.svg" alt="" class="w-16 h-16 mx-auto mb-8 opacity-80" />
    <h1 class="font-heading font-black text-6xl md:text-8xl lg:text-9xl tracking-tight mb-6">
      <span class="text-nr-teal">Open</span><span class="text-white">Source</span>
    </h1>
    <p class="text-xl md:text-2xl text-white/50 font-heading font-light max-w-2xl mx-auto mb-4">
      that ships.
    </p>
    <p class="text-base text-white/50 max-w-lg mx-auto">
      {totalRepos}+ projects powering TYPO3, AI agents, developer tools, and infrastructure.
    </p>
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>
