---
interface Props {
  category: string;
}

const { category } = Astro.props;

// Map categories to icon data
const icons: Record<string, { svg: string; color: string; title: string }> = {
  'CMS Extensions': {
    // TYPO3 logo simplified
    svg: '<path d="M12.28 2C6.75 2 2.28 6.47 2.28 12s4.47 10 9.99 10 10.01-4.47 10.01-10S17.8 2 12.28 2zm2.08 14.77h-4.52l3.13-9.58h4.52l-3.13 9.58z"/>',
    color: '#FF8700',
    title: 'TYPO3 Extension',
  },
  'Developer Tools': {
    // Wrench/tool icon
    svg: '<path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>',
    color: '#2F99A4',
    title: 'Developer Tool',
  },
  'AI/Agent Skills': {
    // Brain/AI icon
    svg: '<path d="M12 2a4 4 0 0 0-4 4v1a4 4 0 0 0-3 3.87V12a4 4 0 0 0 2 3.46V18a4 4 0 0 0 8 0h0a4 4 0 0 0 2-3.46 4 4 0 0 0-1-7.87V6a4 4 0 0 0-4-4zm0 2a2 2 0 0 1 2 2v1.27A4 4 0 0 0 12 7a4 4 0 0 0-2 .27V6a2 2 0 0 1 2-2zM8 9a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v.54a4 4 0 0 0-1-.04h-1a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1c.34 0 .68-.04 1-.13V18a2 2 0 0 1-4 0v-2.54A4 4 0 0 0 8 12V9z"/>',
    color: '#A855F7',
    title: 'AI/Agent Skill',
  },
  'Libraries & SDKs': {
    // Package/library icon
    svg: '<path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>',
    color: '#00ADD8',
    title: 'Library / SDK',
  },
  'Infrastructure & DevOps': {
    // Server/infra icon
    svg: '<path d="M4 6h16a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2zm0 8h16a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-2a2 2 0 0 1 2-2zm2-5h.01M6 17h.01"/>',
    color: '#F97316',
    title: 'Infrastructure',
  },
};

const icon = icons[category];
const isStroke = category === 'Libraries & SDKs' || category === 'Infrastructure & DevOps';
---

{icon && (
  <span class="inline-flex items-center shrink-0" title={icon.title}>
    <svg
      class="w-6 h-6"
      viewBox="0 0 24 24"
      fill={isStroke ? 'none' : icon.color}
      stroke={isStroke ? icon.color : 'none'}
      stroke-width={isStroke ? '2' : '0'}
      stroke-linecap="round"
      stroke-linejoin="round"
      set:html={icon.svg}
    />
  </span>
)}
