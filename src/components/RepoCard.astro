---
import { getLanguageColor } from '../data/language-colors';

interface Props {
  name: string;
  description: string;
  url: string;
  language: string | null;
  stars: number;
  pushed_at: string;
}

const { name, description, url, language, stars, pushed_at } = Astro.props;
const langColor = getLanguageColor(language);
const daysSincePush = Math.floor((Date.now() - new Date(pushed_at).getTime()) / 86400000);
const activityColor = daysSincePush < 30 ? '#3fb950' : daysSincePush < 180 ? '#d29922' : '#8b949e';
const activityLabel = daysSincePush < 30 ? 'Active' : daysSincePush < 180 ? 'Moderately active' : 'Inactive';
---

<a
  href={url}
  target="_blank"
  rel="noopener"
  class="group block rounded-xl border border-border bg-glass p-5 transition-all duration-300 hover:border-border-hover hover:bg-surface-hover hover:-translate-y-0.5 card-shadow"
  data-animate="fade-up"
  aria-label={`${name} — ${description}`}
>
  <div class="flex items-start justify-between mb-2">
    <h3 class="font-heading font-bold text-text-primary/80 group-hover:text-nr-teal transition-colors text-sm truncate pr-2">
      {name}
    </h3>
    {stars > 0 && (
      <span class="flex items-center gap-1 text-xs text-text-secondary shrink-0">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {stars}
      </span>
    )}
  </div>
  <p class="text-xs text-text-secondary line-clamp-2 mb-3 leading-relaxed">{description}</p>
  <div class="flex items-center gap-3 text-xs text-text-secondary">
    {language && (
      <span class="flex items-center gap-1">
        <span class="w-2 h-2 rounded-full" style={`background-color: ${langColor}`} aria-hidden="true"></span>
        {language}
      </span>
    )}
    <span class="flex items-center gap-1" title={activityLabel}>
      <span class="w-1.5 h-1.5 rounded-full" style={`background-color: ${activityColor}`} aria-hidden="true"></span>
      <span class="sr-only">{activityLabel}</span>
    </span>
  </div>
</a>
