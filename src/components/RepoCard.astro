---
import { getLanguageColor } from '../data/language-colors';

interface Props {
  name: string;
  description: string;
  url: string;
  language: string | null;
  stars: number;
  pushed_at: string;
}

const { name, description, url, language, stars, pushed_at } = Astro.props;
const langColor = getLanguageColor(language);
const daysSincePush = Math.floor((Date.now() - new Date(pushed_at).getTime()) / 86400000);
const activityColor = daysSincePush < 30 ? '#3fb950' : daysSincePush < 180 ? '#d29922' : '#8b949e';
---

<a
  href={url}
  target="_blank"
  rel="noopener"
  class="group block rounded-xl border border-white/5 bg-nr-dark-card/30 p-5 transition-all duration-300 hover:border-nr-teal/20 hover:bg-nr-dark-card/60 hover:-translate-y-0.5"
  data-animate="fade-up"
>
  <div class="flex items-start justify-between mb-2">
    <h4 class="font-heading font-bold text-white/80 group-hover:text-nr-teal transition-colors text-sm truncate pr-2">
      {name}
    </h4>
    {stars > 0 && (
      <span class="flex items-center gap-1 text-xs text-white/30 shrink-0">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {stars}
      </span>
    )}
  </div>
  <p class="text-xs text-white/30 line-clamp-2 mb-3 leading-relaxed">{description}</p>
  <div class="flex items-center gap-3 text-xs text-white/20">
    {language && (
      <span class="flex items-center gap-1">
        <span class="w-2 h-2 rounded-full" style={`background-color: ${langColor}`}></span>
        {language}
      </span>
    )}
    <span class="flex items-center gap-1">
      <span class="w-1.5 h-1.5 rounded-full" style={`background-color: ${activityColor}`}></span>
    </span>
  </div>
</a>
