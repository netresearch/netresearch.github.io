---
import RepoCard from './RepoCard.astro';
import type { Category } from '../data/categories';
import type { RepoProject } from '../data/load-projects';

interface Props {
  category: Category;
  repos: RepoProject[];
  alternateBackground?: boolean;
}

const { category, repos, alternateBackground = false } = Astro.props;
---

{repos.length > 0 && (
  <section id={category.id} class:list={["py-20 relative", alternateBackground && "bg-surface-alt"]}>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-12" data-animate="fade-up">
        <h2 class="text-sm font-heading uppercase tracking-[0.2em] text-nr-teal mb-3">{category.title}</h2>
        <div class="w-12 h-0.5 bg-nr-teal/30"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {repos.map((repo) => (
          <RepoCard
            name={repo.name}
            description={repo.description}
            url={repo.url}
            language={repo.language}
            stars={repo.stars}
            pushed_at={repo.pushed_at}
          />
        ))}
      </div>
      {category.servicePromo && (
        <p class="mt-10 text-sm text-text-muted text-center">
          {category.servicePromo}{' '}
          <a href="https://www.netresearch.de/" class="text-nr-teal hover:underline" target="_blank" rel="noopener">Learn more &rarr;</a>
        </p>
      )}
    </div>
  </section>
)}
