---
import Badge from './Badge.astro';
import CategoryIcon from './CategoryIcon.astro';
import { getLanguageColor } from '../data/language-colors';
import type { FeaturedProject } from '../data/load-projects';

interface Props {
  project: FeaturedProject;
  index: number;
}

const { project, index } = Astro.props;
const isEven = index % 2 === 0;
const langColor = getLanguageColor(project.language);

function timeAgo(dateStr: string | undefined): string {
  if (!dateStr) return '';
  const diff = Date.now() - new Date(dateStr).getTime();
  const days = Math.floor(diff / 86400000);
  if (days < 1) return 'today';
  if (days < 30) return `${days}d ago`;
  if (days < 365) return `${Math.floor(days / 30)}mo ago`;
  return `${Math.floor(days / 365)}y ago`;
}

const updatedAgo = timeAgo(project.pushed_at);
---

<div
  class:list={[
    'group relative rounded-2xl border border-border bg-glass backdrop-blur-sm p-8 transition-all duration-500 hover:border-border-hover card-shadow hover:shadow-[0_0_40px_-12px_rgba(47,153,164,0.15)]',
    isEven ? 'md:translate-x-4' : 'md:-translate-x-4',
  ]}
  data-animate={isEven ? 'slide-right' : 'slide-left'}
>
  <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-nr-teal/0 via-nr-teal/5 to-nr-orange/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

  <div class="relative z-10">
    <div class="flex items-start justify-between mb-4">
      <h3 class="flex items-center gap-2 text-2xl font-heading font-bold text-text-primary group-hover:text-nr-teal transition-colors">
        <CategoryIcon category={project.category} />
        {project.name}
      </h3>
      <div class="flex items-center gap-3 text-sm text-text-secondary">
        {project.language && (
          <span class="flex items-center gap-1.5">
            <span class="w-3 h-3 rounded-full" style={`background-color: ${langColor}`}></span>
            {project.language}
          </span>
        )}
        {project.stars !== undefined && (
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {project.stars}
          </span>
        )}
      </div>
    </div>

    <p class="text-text-secondary leading-relaxed mb-6 max-w-2xl">{project.description}</p>

    {project.qualityBadges && project.qualityBadges.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-4">
        {project.qualityBadges.map((badge) => (
          <img
            src={badge.url}
            alt={badge.alt}
            class="h-5"
            loading="lazy"
          />
        ))}
      </div>
    )}

    <div class="flex flex-wrap items-center gap-3">
      {project.latestRelease && (
        <span class="text-xs font-mono text-nr-teal bg-nr-teal/5 px-2 py-1 rounded">
          {project.latestRelease}
        </span>
      )}
      {updatedAgo && (
        <span class="text-xs text-text-muted">Updated {updatedAgo}</span>
      )}
      <div class="flex-1"></div>
      <div class="flex flex-wrap gap-2">
        <Badge type="github" url={project.url || `https://github.com/${project.repo}`} label="GitHub" projectName={project.name} />
        {project.links?.map((link) => (
          <Badge type={link.type} url={link.url} label={link.label} projectName={project.name} />
        ))}
      </div>
    </div>
  </div>
</div>
